# Demo mode — runs simulated pipeline without provider API keys
DEMO_MODE=true
DEBUG=true

TENANT_ID=demo-workspace

# CORS (console + verifier dev ports)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=sqlite+aiosqlite:///./attest.db

# Backblaze B2 — use Application Key ID + secret (Master Key works via native API)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_REGION=us-east-005
# Optional — leave empty for private bucket (uses /api/storage/… proxy URLs)
# Correct:  B2_PUBLIC_URL_BASE=https://attest-dma-2026.s3.us-east-005.backblazeb2.com
# Wrong:    B2_PUBLIC_URL_BASE=B2_PUBLIC_URL_BASE=https://...
B2_PUBLIC_URL_BASE=

# Optional — when set, POST /api/webhooks/b2 requires X-Attest-Signature header
B2_WEBHOOK_SECRET=

# Ed25519 signing (Mode 2) — generate once, never rotate during hackathon
# Private seed: 64 hex chars (32 bytes). Public raw key: 64 hex chars.
# Committed public PEM: frontend/public/attest-pubkey.pem
ATTEST_SIGNING_KEY_HEX=
ATTEST_VERIFY_KEY_HEX=

API_PUBLIC_BASE_URL=http://localhost:8000

# Provider keys — GMI Cloud ($5 Devpost credits) preferred over Replicate
GMI_API_KEY=
REPLICATE_API_TOKEN=
