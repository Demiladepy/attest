# Demo mode — runs simulated pipeline without provider API keys
DEMO_MODE=true
DEBUG=true

TENANT_ID=demo-workspace

# CORS (console + verifier dev ports)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=sqlite+aiosqlite:///./attest.db

# Backblaze B2 (leave empty for demo mode)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_REGION=us-west-004
B2_PUBLIC_URL_BASE=

# Ed25519 signing (Mode 2) — generate once, never rotate during hackathon
# Private seed: 64 hex chars (32 bytes). Public raw key: 64 hex chars.
# Committed public PEM: frontend/public/attest-pubkey.pem
ATTEST_SIGNING_KEY_HEX=
ATTEST_VERIFY_KEY_HEX=

B2_WEBHOOK_SECRET=
